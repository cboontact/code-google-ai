DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=google_ai_cert
ADMIN_PASSWORD=change-this-password

# Optional: Hostatom FTP deploy script
FTP_HOST=your_ftp_host
FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password
FTP_REMOTE_DIR=/google-ai.chomthongschool.ac.th

# Optional: production env generated by ftp_upload.py
PROD_DB_HOST=localhost
PROD_DB_PORT=3306
PROD_DB_USER=your_prod_db_user
PROD_DB_PASSWORD=your_prod_db_password
PROD_DB_NAME=your_prod_db_name
PROD_ADMIN_PASSWORD=change-this-production-password
